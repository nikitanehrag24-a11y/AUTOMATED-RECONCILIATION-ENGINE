# Central settings for Reconciliation Engine
ENVIRONMENT=development
PORT=8000

# Database Configuration
# For local run: postgresql://postgres:postgres@localhost:5432/recon_db
# For Docker run: postgresql://postgres:postgres@db:5432/recon_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recon_db

# Cache Configuration
# For local run: redis://localhost:6379/0
# For Docker run: redis://cache:6379/0
REDIS_URL=redis://localhost:6379/0

# Security
API_KEY=your-super-secret-api-key-placeholder
JWT_SECRET=your-jwt-secret-signing-key-placeholder
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
